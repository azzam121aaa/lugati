<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>الدروس - منصة لغتي</title>

  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{
      font-family:Tahoma,Arial,sans-serif;
      min-height:100vh;
      background:linear-gradient(135deg,#fff7ed,#ffffff);
    }

    .container{width:min(1100px,92%);margin:28px auto}

    .topbar{
      background:linear-gradient(90deg,#f97316,#fb923c);
      color:#fff;
      padding:18px;
      border-radius:20px;
      text-align:center;
      font-size:28px;
      font-weight:800;
      margin-bottom:20px;
    }

    .grid{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:16px;
    }

    .card{
      display:block;
      text-decoration:none;
      color:#000;
      background:#fff;
      border-radius:20px;
      padding:20px;
      border:1px solid #eee;
      transition:.2s;
    }

    .card:hover{transform:translateY(-5px)}

    .num{
      width:45px;height:45px;
      background:#f97316;
      color:#fff;
      display:flex;
      align-items:center;
      justify-content:center;
      border-radius:12px;
      font-weight:bold;
      margin-bottom:10px;
    }

    @media(max-width:900px){
      .grid{grid-template-columns:repeat(2,1fr)}
    }

    @media(max-width:600px){
      .grid{grid-template-columns:1fr}
    }
  </style>
</head>

<body>
<div class="container">

  <div class="topbar">📘 دروس مادة لغتي</div>

  <div class="grid">

    <!-- إذا ملفاتك في نفس المجلد -->
    <a class="card" href="./lesson1.html">
      <div class="num">1</div>
      <h3>أسلوب الشرط والتوكيد</h3>
    </a>

    <a class="card" href="./lesson2.html">
      <div class="num">2</div>
      <h3>تنوين الاسم المقصور والمنقوص والممدود</h3>
    </a>

    <a class="card" href="./lesson3.html">
      <div class="num">3</div>
      <h3>الألف اللينة</h3>
    </a>

    <a class="card" href="./lesson4.html">
      <div class="num">4</div>
      <h3>حروف الجر</h3>
    </a>

    <a class="card" href="./lesson5.html">
      <div class="num">5</div>
      <h3>رفع الفعل المضارع</h3>
    </a>

    <a class="card" href="./lesson6.html">
      <div class="num">6</div>
      <h3>نصب الفعل المضارع</h3>
    </a>

    <a class="card" href="./lesson7.html">
      <div class="num">7</div>
      <h3>جزم الفعل المضارع</h3>
    </a>

    <a class="card" href="./lesson8.html">
      <div class="num">8</div>
      <h3>اسم الزمان والمكان</h3>
    </a>

    <a class="card" href="./lesson9.html">
      <div class="num">9</div>
      <h3>المشتقات والمصادر</h3>
    </a>

  </div>

</div>
</body>
</html>
